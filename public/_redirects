# Netlify redirects
# Static files (sitemap.xml, robots.txt, favicon.ico) are served directly
# by Netlify without needing explicit rules — no entries needed for them.

# Image fallback: serve from lovable-uploads if not found at original path
*.png /lovable-uploads/:splat 200
*.jpg /lovable-uploads/:splat 200
*.jpeg /lovable-uploads/:splat 200
*.svg /lovable-uploads/:splat 200

# API routes
/api/* /api/:splat 200

# React Router fallback for all other routes
/* /index.html 200
